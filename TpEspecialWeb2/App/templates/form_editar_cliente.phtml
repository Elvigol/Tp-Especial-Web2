<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <base href="<?= BASE_URL ?>">
    <link rel="stylesheet" href="css/style.css">
    <title>Editar Cliente</title>
</head>
<body>
    <div class="contenedor-formulario">
        <h2 class="titulo-principal">Editar Cliente</h2>

        <form action="update-cliente/<?= $cliente->id_cliente ?>" method="POST" class="formulario-alta">

            <div class="grupo-form">
                <label for="nombre" class="descripcion">Nombre del Cliente (Categoría):</label>
                <input type="text" id="nombre" name="nombre" value="<?= $cliente->nombre ?>" required>
            </div>

            <div class="grupo-form">
                <label for="email" class="descripcion">Email de Contacto:</label>
                <input type="email" id="email" name="email" value="<?= $cliente->email ?>" required>
            </div>

            <div class="grupo-form">
                <label for="imagen_url" class="descripcion">URL de la Foto (Opcional):</label>
                <input type="url" id="imagen_url" name="imagen_url" value="<?= $cliente->imagen_url ?>" placeholder="Ej: https://.../foto.jpg">
            </div>

            <button type="submit" class="boton-guardar">
                Actualizar Cliente
            </button>
            <a href="clientes" class="enlace-cancelar">Cancelar y volver</a>
        </form>
    </div>
</body>
</html>